@startuml
left to right direction

actor Customer as "Клиент"
actor Manager as "Менеджер"

rectangle "VIP Table Booking System" {

  usecase UC1 as "Просмотр VIP-столиков"
  usecase UC2 as "Просмотр доступности столика"
  usecase UC3 as "Создание бронирования"
  usecase UC4 as "Отмена бронирования"

  usecase UC5 as "Просмотр всех бронирований"
  usecase UC6 as "Подтверждение бронирования"
  usecase UC7 as "Отмена бронирования менеджером"

}

Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4

Manager --> UC5
Manager --> UC6
Manager --> UC7

@enduml
